# =============================================================
# Asset Management Platform - Environment Configuration
# Copy this file to .env and fill in real values
# =============================================================

# ---- App ----
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=asset_user
POSTGRES_PASSWORD=asset_password
POSTGRES_DB=asset_management
DATABASE_URL=postgresql://asset_user:asset_password@localhost:5432/asset_management

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Blockchain ----
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=your-private-key-never-commit-this
ASSET_TOKEN_CONTRACT_ADDRESS=
MARKETPLACE_CONTRACT_ADDRESS=
ESCROW_CONTRACT_ADDRESS=

# ---- IPFS / Pinata ----
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ---- Email ----
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
EMAIL_FROM=noreply@assetmgmt.local

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- PgAdmin (Docker tools profile) ----
PGADMIN_EMAIL=admin@asset.local
PGADMIN_PASSWORD=admin_password
